{
  "title": "RFQ Market Maker Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "stat",
      "title": "Quote Requests",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "rfq_quote_requests_total",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Quote Responses",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "rfq_quote_responses_total",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Submit Requests",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "rfq_submit_requests_total",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Settlements",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 4, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "rfq_settlements_total",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Hedge Intent Errors",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 4, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "sum(rfq_hedge_intent_errors_total)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Quote Status Update Errors",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "sum(rfq_quote_status_update_errors_total)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "PnL Record Errors",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "sum(rfq_pnl_record_errors_total)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Inventory Balance",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "rfq_inventory_balance",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Realized PnL",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "rfq_realized_pnl_token_out",
          "refId": "A"
        }
      ]

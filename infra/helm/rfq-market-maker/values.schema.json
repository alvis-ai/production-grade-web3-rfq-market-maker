{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["env", "image", "networkPolicy"],
  "properties": {
    "env": {
      "type": "object",
      "required": ["NODE_ENV"],
      "properties": {
        "NODE_ENV": {
          "const": "production"
        }
      },
      "additionalProperties": true
    },
    "image": {
      "type": "object",
      "required": ["repository", "tag", "digest", "pullPolicy"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1,
          "not": {
            "const": "latest"
          }
        },
        "digest": {
          "oneOf": [
            {
              "const": ""
            },
            {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          ]
        },
        "pullPolicy": {
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "additionalProperties": false
    },
    "networkPolicy": {
      "type": "object",
      "required": ["enabled", "apiIngressNamespaceLabels", "monitoringNamespaceLabels"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "apiIngressNamespaceLabels": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "monitoringNamespaceLabels": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}

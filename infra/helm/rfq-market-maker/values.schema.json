{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "definitions": {
    "fqdnEndpoint": {
      "type": "object",
      "required": ["hostname", "port"],
      "properties": {
        "hostname": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^(?:[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?\\.)+[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?$"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      },
      "additionalProperties": false
    },
    "fqdnEndpointList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/fqdnEndpoint"
      }
    },
    "hpaScalingRules": {
      "type": "object",
      "required": ["stabilizationWindowSeconds", "selectPolicy", "policies"],
      "properties": {
        "stabilizationWindowSeconds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3600
        },
        "selectPolicy": {
          "enum": ["Max", "Min"]
        },
        "policies": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "items": {
            "type": "object",
            "required": ["type", "value", "periodSeconds"],
            "properties": {
              "type": {
                "enum": ["Pods", "Percent"]
              },
              "value": {
                "type": "integer",
                "minimum": 1
              },
              "periodSeconds": {
                "type": "integer",
                "minimum": 1,
                "maximum": 1800
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "replicatedWorker": {
      "type": "object",
      "required": ["enabled", "replicaCount"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "replicaCount": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled": {
                "const": true
              }
            },
            "required": ["enabled"]
          },
          "then": {
            "properties": {
              "replicaCount": {
                "minimum": 2
              }
            }
          }
        }
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "env",
    "image",
    "networkPolicy",
    "podSecurityContext",
    "containerSecurityContext",
    "tmpVolumeSizeLimit",
    "serviceAccount",
    "autoscaling",
    "disruptionBudget",
    "replicaCount",
    "hedgeWorker",
    "analyticsWorker",
    "reconciliationWorker",
    "settlementIndexer",
    "toxicFlowAnalyzer"
  ],
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 2,
      "maximum": 100
    },
    "tmpVolumeSizeLimit": {
      "const": "16Mi"
    },
    "podSecurityContext": {
      "type": "object",
      "required": [
        "runAsNonRoot",
        "runAsUser",
        "runAsGroup",
        "fsGroup",
        "fsGroupChangePolicy",
        "seccompProfile"
      ],
      "properties": {
        "runAsNonRoot": {
          "const": true
        },
        "runAsUser": {
          "const": 1000
        },
        "runAsGroup": {
          "const": 1000
        },
        "fsGroup": {
          "const": 1000
        },
        "fsGroupChangePolicy": {
          "const": "OnRootMismatch"
        },
        "seccompProfile": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {
              "const": "RuntimeDefault"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "containerSecurityContext": {
      "type": "object",
      "required": ["allowPrivilegeEscalation", "readOnlyRootFilesystem", "capabilities"],
      "properties": {
        "allowPrivilegeEscalation": {
          "const": false
        },
        "readOnlyRootFilesystem": {
          "const": true
        },
        "capabilities": {
          "type": "object",
          "required": ["drop"],
          "properties": {
            "drop": {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "items": {
                "const": "ALL"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "serviceAccount": {
      "type": "object",
      "required": ["automountServiceAccountToken"],
      "properties": {
        "automountServiceAccountToken": {
          "const": false
        }
      },
      "additionalProperties": true
    },
    "autoscaling": {
      "type": "object",
      "required": [
        "enabled",
        "minReplicas",
        "maxReplicas",
        "targetCPUUtilizationPercentage",
        "behavior"
      ],
      "properties": {
        "enabled": {
          "const": true
        },
        "minReplicas": {
          "type": "integer",
          "minimum": 2,
          "maximum": 20
        },
        "maxReplicas": {
          "type": "integer",
          "minimum": 2,
          "maximum": 100
        },
        "targetCPUUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "behavior": {
          "type": "object",
          "required": ["scaleUp", "scaleDown"],
          "properties": {
            "scaleUp": {
              "$ref": "#/definitions/hpaScalingRules"
            },
            "scaleDown": {
              "$ref": "#/definitions/hpaScalingRules"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "disruptionBudget": {
      "type": "object",
      "required": ["enabled", "maxUnavailable", "unhealthyPodEvictionPolicy"],
      "properties": {
        "enabled": {
          "const": true
        },
        "maxUnavailable": {
          "const": 1
        },
        "unhealthyPodEvictionPolicy": {
          "const": "AlwaysAllow"
        }
      },
      "additionalProperties": false
    },
    "hedgeWorker": {
      "$ref": "#/definitions/replicatedWorker"
    },
    "analyticsWorker": {
      "$ref": "#/definitions/replicatedWorker"
    },
    "reconciliationWorker": {
      "$ref": "#/definitions/replicatedWorker"
    },
    "settlementIndexer": {
      "$ref": "#/definitions/replicatedWorker"
    },
    "toxicFlowAnalyzer": {
      "$ref": "#/definitions/replicatedWorker"
    },
    "env": {
      "type": "object",
      "required": ["NODE_ENV"],
      "properties": {
        "NODE_ENV": {
          "const": "production"
        }
      },
      "additionalProperties": true
    },
    "image": {
      "type": "object",
      "required": ["repository", "tag", "digest", "pullPolicy"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1,
          "not": {
            "const": "latest"
          }
        },
        "digest": {
          "oneOf": [
            {
              "const": ""
            },
            {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          ]
        },
        "pullPolicy": {
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "additionalProperties": false
    },
    "networkPolicy": {
      "type": "object",
      "required": ["enabled", "apiIngressNamespaceLabels", "monitoringNamespaceLabels", "fqdnEgress"],
      "properties": {
        "enabled": {
          "const": true
        },
        "apiIngressNamespaceLabels": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "monitoringNamespaceLabels": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "fqdnEgress": {
          "type": "object",
          "required": [
            "enabled",
            "dns",
            "api",
            "hedgeWorker",
            "analyticsWorker",
            "reconciliationWorker",
            "settlementIndexer",
            "toxicFlowAnalyzer"
          ],
          "properties": {
            "enabled": {
              "const": true
            },
            "dns": {
              "type": "object",
              "required": ["endpointLabels", "port"],
              "properties": {
                "endpointLabels": {
                  "type": "object",
                  "minProperties": 1,
                  "additionalProperties": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "port": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 65535
                }
              },
              "additionalProperties": false
            },
            "api": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "hedgeWorker": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "analyticsWorker": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "reconciliationWorker": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "settlementIndexer": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "toxicFlowAnalyzer": {
              "$ref": "#/definitions/fqdnEndpointList"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "definitions": {
    "fqdnEndpoint": {
      "type": "object",
      "required": ["hostname", "port"],
      "properties": {
        "hostname": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^(?:[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?\\.)+[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?$"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      },
      "additionalProperties": false
    },
    "fqdnEndpointList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/fqdnEndpoint"
      }
    }
  },
  "required": [
    "env",
    "image",
    "networkPolicy",
    "podSecurityContext",
    "containerSecurityContext",
    "tmpVolumeSizeLimit",
    "serviceAccount"
  ],
  "properties": {
    "tmpVolumeSizeLimit": {
      "const": "16Mi"
    },
    "podSecurityContext": {
      "type": "object",
      "required": [
        "runAsNonRoot",
        "runAsUser",
        "runAsGroup",
        "fsGroup",
        "fsGroupChangePolicy",
        "seccompProfile"
      ],
      "properties": {
        "runAsNonRoot": {
          "const": true
        },
        "runAsUser": {
          "const": 1000
        },
        "runAsGroup": {
          "const": 1000
        },
        "fsGroup": {
          "const": 1000
        },
        "fsGroupChangePolicy": {
          "const": "OnRootMismatch"
        },
        "seccompProfile": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {
              "const": "RuntimeDefault"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "containerSecurityContext": {
      "type": "object",
      "required": ["allowPrivilegeEscalation", "readOnlyRootFilesystem", "capabilities"],
      "properties": {
        "allowPrivilegeEscalation": {
          "const": false
        },
        "readOnlyRootFilesystem": {
          "const": true
        },
        "capabilities": {
          "type": "object",
          "required": ["drop"],
          "properties": {
            "drop": {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "items": {
                "const": "ALL"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "serviceAccount": {
      "type": "object",
      "required": ["automountServiceAccountToken"],
      "properties": {
        "automountServiceAccountToken": {
          "const": false
        }
      },
      "additionalProperties": true
    },
    "env": {
      "type": "object",
      "required": ["NODE_ENV"],
      "properties": {
        "NODE_ENV": {
          "const": "production"
        }
      },
      "additionalProperties": true
    },
    "image": {
      "type": "object",
      "required": ["repository", "tag", "digest", "pullPolicy"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1,
          "not": {
            "const": "latest"
          }
        },
        "digest": {
          "oneOf": [
            {
              "const": ""
            },
            {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          ]
        },
        "pullPolicy": {
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "additionalProperties": false
    },
    "networkPolicy": {
      "type": "object",
      "required": ["enabled", "apiIngressNamespaceLabels", "monitoringNamespaceLabels", "fqdnEgress"],
      "properties": {
        "enabled": {
          "const": true
        },
        "apiIngressNamespaceLabels": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "monitoringNamespaceLabels": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "fqdnEgress": {
          "type": "object",
          "required": [
            "enabled",
            "dns",
            "api",
            "hedgeWorker",
            "analyticsWorker",
            "reconciliationWorker",
            "settlementIndexer",
            "toxicFlowAnalyzer"
          ],
          "properties": {
            "enabled": {
              "const": true
            },
            "dns": {
              "type": "object",
              "required": ["endpointLabels", "port"],
              "properties": {
                "endpointLabels": {
                  "type": "object",
                  "minProperties": 1,
                  "additionalProperties": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "port": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 65535
                }
              },
              "additionalProperties": false
            },
            "api": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "hedgeWorker": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "analyticsWorker": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "reconciliationWorker": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "settlementIndexer": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "toxicFlowAnalyzer": {
              "$ref": "#/definitions/fqdnEndpointList"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "definitions": {
    "fqdnEndpoint": {
      "type": "object",
      "required": ["hostname", "port"],
      "properties": {
        "hostname": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^(?:[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?\\.)+[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?$"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      },
      "additionalProperties": false
    },
    "fqdnEndpointList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/fqdnEndpoint"
      }
    },
    "hpaScalingRules": {
      "type": "object",
      "required": ["stabilizationWindowSeconds", "selectPolicy", "policies"],
      "properties": {
        "stabilizationWindowSeconds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3600
        },
        "selectPolicy": {
          "enum": ["Max", "Min"]
        },
        "policies": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "items": {
            "type": "object",
            "required": ["type", "value", "periodSeconds"],
            "properties": {
              "type": {
                "enum": ["Pods", "Percent"]
              },
              "value": {
                "type": "integer",
                "minimum": 1
              },
              "periodSeconds": {
                "type": "integer",
                "minimum": 1,
                "maximum": 1800
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "replicatedWorker": {
      "type": "object",
      "required": ["enabled", "replicaCount"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "replicaCount": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled": {
                "const": true
              }
            },
            "required": ["enabled"]
          },
          "then": {
            "properties": {
              "replicaCount": {
                "minimum": 2
              }
            }
          }
        }
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "env",
    "image",
    "networkPolicy",
    "podSecurityContext",
    "containerSecurityContext",
    "tmpVolumeSizeLimit",
    "serviceAccount",
    "signerService",
    "autoscaling",
    "disruptionBudget",
    "topologySpread",
    "terminationGracePeriodSeconds",
    "preStopSleepSeconds",
    "replicaCount",
    "hedgeWorker",
    "analyticsWorker",
    "reconciliationWorker",
    "settlementIndexer",
    "toxicFlowAnalyzer",
    "frontend"
  ],
  "properties": {
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "minimum": 10,
      "maximum": 600
    },
    "preStopSleepSeconds": {
      "type": "integer",
      "minimum": 0,
      "maximum": 300
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 2,
      "maximum": 100
    },
    "tmpVolumeSizeLimit": {
      "const": "16Mi"
    },
    "podSecurityContext": {
      "type": "object",
      "required": [
        "runAsNonRoot",
        "runAsUser",
        "runAsGroup",
        "fsGroup",
        "fsGroupChangePolicy",
        "seccompProfile"
      ],
      "properties": {
        "runAsNonRoot": {
          "const": true
        },
        "runAsUser": {
          "const": 1000
        },
        "runAsGroup": {
          "const": 1000
        },
        "fsGroup": {
          "const": 1000
        },
        "fsGroupChangePolicy": {
          "const": "OnRootMismatch"
        },
        "seccompProfile": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {
              "const": "RuntimeDefault"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "containerSecurityContext": {
      "type": "object",
      "required": ["allowPrivilegeEscalation", "readOnlyRootFilesystem", "capabilities"],
      "properties": {
        "allowPrivilegeEscalation": {
          "const": false
        },
        "readOnlyRootFilesystem": {
          "const": true
        },
        "capabilities": {
          "type": "object",
          "required": ["drop"],
          "properties": {
            "drop": {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "items": {
                "const": "ALL"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "serviceAccount": {
      "type": "object",
      "required": ["automountServiceAccountToken"],
      "properties": {
        "automountServiceAccountToken": {
          "const": false
        }
      },
      "additionalProperties": true
    },
    "signerService": {
      "type": "object",
      "required": ["enabled", "replicaCount", "port", "serviceAccount", "secret", "awsRegion", "awsMaxAttempts", "maxClockSkewSeconds", "bodyLimitBytes", "auditTimeoutMs", "resources"],
      "properties": {
        "enabled": { "const": true },
        "replicaCount": { "type": "integer", "minimum": 2, "maximum": 20 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "serviceAccount": { "type": "object" },
        "secret": {
          "type": "object",
          "required": ["name", "kmsKeyIdKey", "authTokenKey", "trustedSignerAddressKey", "settlementAddressKey", "auditDatabaseUrlKey", "tlsCertKey", "tlsKeyKey", "databaseCaCertKey"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "kmsKeyIdKey": { "type": "string", "minLength": 1 },
            "authTokenKey": { "type": "string", "minLength": 1 },
            "trustedSignerAddressKey": { "type": "string", "minLength": 1 },
            "settlementAddressKey": { "type": "string", "minLength": 1 },
            "auditDatabaseUrlKey": { "type": "string", "minLength": 1 },
            "tlsCertKey": { "type": "string", "minLength": 1 },
            "tlsKeyKey": { "type": "string", "minLength": 1 },
            "databaseCaCertKey": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "awsRegion": { "type": "string", "minLength": 1 },
        "awsMaxAttempts": { "type": "integer", "minimum": 1, "maximum": 10 },
        "maxClockSkewSeconds": { "type": "integer", "minimum": 0, "maximum": 60 },
        "bodyLimitBytes": { "type": "integer", "minimum": 1024, "maximum": 1048576 },
        "auditTimeoutMs": { "type": "integer", "minimum": 100, "maximum": 10000 },
        "resources": { "type": "object" }
      },
      "additionalProperties": false
    },
    "autoscaling": {
      "type": "object",
      "required": [
        "enabled",
        "minReplicas",
        "maxReplicas",
        "targetCPUUtilizationPercentage",
        "behavior"
      ],
      "properties": {
        "enabled": {
          "const": true
        },
        "minReplicas": {
          "type": "integer",
          "minimum": 2,
          "maximum": 20
        },
        "maxReplicas": {
          "type": "integer",
          "minimum": 2,
          "maximum": 100
        },
        "targetCPUUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "behavior": {
          "type": "object",
          "required": ["scaleUp", "scaleDown"],
          "properties": {
            "scaleUp": {
              "$ref": "#/definitions/hpaScalingRules"
            },
            "scaleDown": {
              "$ref": "#/definitions/hpaScalingRules"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "disruptionBudget": {
      "type": "object",
      "required": ["enabled", "maxUnavailable", "unhealthyPodEvictionPolicy"],
      "properties": {
        "enabled": {
          "const": true
        },
        "maxUnavailable": {
          "const": 1
        },
        "unhealthyPodEvictionPolicy": {
          "const": "AlwaysAllow"
        }
      },
      "additionalProperties": false
    },
    "topologySpread": {
      "type": "object",
      "required": [
        "enabled",
        "maxSkew",
        "minDomains",
        "whenUnsatisfiable",
        "topologyKeys"
      ],
      "properties": {
        "enabled": {
          "const": true
        },
        "maxSkew": {
          "const": 1
        },
        "minDomains": {
          "const": 2
        },
        "whenUnsatisfiable": {
          "const": "DoNotSchedule"
        },
        "topologyKeys": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": [
              "kubernetes.io/hostname",
              "topology.kubernetes.io/zone"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "hedgeWorker": {
      "$ref": "#/definitions/replicatedWorker"
    },
    "analyticsWorker": {
      "$ref": "#/definitions/replicatedWorker"
    },
    "reconciliationWorker": {
      "$ref": "#/definitions/replicatedWorker"
    },
    "settlementIndexer": {
      "$ref": "#/definitions/replicatedWorker"
    },
    "toxicFlowAnalyzer": {
      "$ref": "#/definitions/replicatedWorker"
    },
    "frontend": {
      "type": "object",
      "required": [
        "enabled",
        "replicaCount",
        "image",
        "service",
        "apiKeySecret",
        "runtimeConfig",
        "ingress",
        "podSecurityContext",
        "containerSecurityContext",
        "resources"
      ],
      "properties": {
        "enabled": {
          "const": true
        },
        "replicaCount": {
          "type": "integer",
          "minimum": 2,
          "maximum": 100
        },
        "image": {
          "type": "object",
          "required": ["repository", "tag", "digest", "pullPolicy"],
          "properties": {
            "repository": {
              "type": "string",
              "minLength": 1
            },
            "tag": {
              "type": "string",
              "minLength": 1,
              "not": { "const": "latest" }
            },
            "digest": {
              "oneOf": [
                { "const": "" },
                { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
              ]
            },
            "pullPolicy": {
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          },
          "additionalProperties": false
        },
        "service": {
          "type": "object",
          "required": ["port"],
          "properties": {
            "port": { "const": 8080 }
          },
          "additionalProperties": false
        },
        "apiKeySecret": {
          "type": "object",
          "required": ["name", "configKey"],
          "properties": {
            "name": {
              "type": "string",
              "pattern": "^[a-z0-9](?:[-a-z0-9]*[a-z0-9])?$",
              "maxLength": 253
            },
            "configKey": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._-]+$",
              "maxLength": 253
            }
          },
          "additionalProperties": false
        },
        "runtimeConfig": {
          "type": "object",
          "required": ["settlementAddress", "walletConnectProjectId"],
          "properties": {
            "settlementAddress": {
              "oneOf": [
                { "const": "" },
                { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" }
              ]
            },
            "walletConnectProjectId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_-]+$",
              "maxLength": 128
            }
          },
          "additionalProperties": false
        },
        "ingress": {
          "type": "object",
          "required": ["enabled", "className", "host", "tlsSecretName", "sourceRanges"],
          "properties": {
            "enabled": { "const": true },
            "className": {
              "type": "string",
              "minLength": 1,
              "maxLength": 63
            },
            "host": {
              "type": "string",
              "maxLength": 253,
              "pattern": "^(?:[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?\\.)+[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?$"
            },
            "tlsSecretName": {
              "type": "string",
              "pattern": "^[a-z0-9](?:[-a-z0-9]*[a-z0-9])?$",
              "maxLength": 253
            },
            "sourceRanges": {
              "type": "array",
              "minItems": 1,
              "maxItems": 64,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^[0-9A-Fa-f:.]+/[0-9]{1,3}$",
                "not": { "enum": ["0.0.0.0/0", "::/0"] }
              }
            }
          },
          "additionalProperties": false
        },
        "podSecurityContext": {
          "type": "object",
          "required": ["runAsNonRoot", "runAsUser", "runAsGroup", "fsGroup", "fsGroupChangePolicy", "seccompProfile"],
          "properties": {
            "runAsNonRoot": { "const": true },
            "runAsUser": { "const": 101 },
            "runAsGroup": { "const": 101 },
            "fsGroup": { "const": 101 },
            "fsGroupChangePolicy": { "const": "OnRootMismatch" },
            "seccompProfile": {
              "type": "object",
              "required": ["type"],
              "properties": { "type": { "const": "RuntimeDefault" } },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "containerSecurityContext": {
          "type": "object",
          "required": ["allowPrivilegeEscalation", "readOnlyRootFilesystem", "capabilities"],
          "properties": {
            "allowPrivilegeEscalation": { "const": false },
            "readOnlyRootFilesystem": { "const": true },
            "capabilities": {
              "type": "object",
              "required": ["drop"],
              "properties": {
                "drop": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 1,
                  "items": { "const": "ALL" }
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "resources": {
          "type": "object",
          "required": ["requests", "limits"],
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "env": {
      "type": "object",
      "required": ["NODE_ENV", "RFQ_SHUTDOWN_TIMEOUT_MS"],
      "properties": {
        "NODE_ENV": {
          "const": "production"
        },
        "RFQ_SHUTDOWN_TIMEOUT_MS": {
          "type": "string",
          "pattern": "^(?:[1-9][0-9]{3,4}|1[01][0-9]{4}|120000)$"
        }
      },
      "additionalProperties": true
    },
    "image": {
      "type": "object",
      "required": ["repository", "tag", "digest", "pullPolicy"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1,
          "not": {
            "const": "latest"
          }
        },
        "digest": {
          "oneOf": [
            {
              "const": ""
            },
            {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          ]
        },
        "pullPolicy": {
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "additionalProperties": false
    },
    "networkPolicy": {
      "type": "object",
      "required": ["enabled", "apiIngressNamespaceLabels", "monitoringNamespaceLabels", "fqdnEgress"],
      "properties": {
        "enabled": {
          "const": true
        },
        "apiIngressNamespaceLabels": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "monitoringNamespaceLabels": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "fqdnEgress": {
          "type": "object",
          "required": [
            "enabled",
            "dns",
            "api",
            "signer",
            "hedgeWorker",
            "analyticsWorker",
            "reconciliationWorker",
            "settlementIndexer",
            "toxicFlowAnalyzer"
          ],
          "properties": {
            "enabled": {
              "const": true
            },
            "dns": {
              "type": "object",
              "required": ["endpointLabels", "port"],
              "properties": {
                "endpointLabels": {
                  "type": "object",
                  "minProperties": 1,
                  "additionalProperties": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "port": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 65535
                }
              },
              "additionalProperties": false
            },
            "api": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "signer": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "hedgeWorker": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "analyticsWorker": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "reconciliationWorker": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "settlementIndexer": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "toxicFlowAnalyzer": {
              "$ref": "#/definitions/fqdnEndpointList"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "definitions": {
    "fqdnEndpoint": {
      "type": "object",
      "required": ["hostname", "port"],
      "properties": {
        "hostname": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^(?:[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?\\.)+[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?$"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      },
      "additionalProperties": false
    },
    "fqdnEndpointList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/fqdnEndpoint"
      }
    }
  },
  "required": ["env", "image", "networkPolicy"],
  "properties": {
    "env": {
      "type": "object",
      "required": ["NODE_ENV"],
      "properties": {
        "NODE_ENV": {
          "const": "production"
        }
      },
      "additionalProperties": true
    },
    "image": {
      "type": "object",
      "required": ["repository", "tag", "digest", "pullPolicy"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1,
          "not": {
            "const": "latest"
          }
        },
        "digest": {
          "oneOf": [
            {
              "const": ""
            },
            {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          ]
        },
        "pullPolicy": {
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "additionalProperties": false
    },
    "networkPolicy": {
      "type": "object",
      "required": ["enabled", "apiIngressNamespaceLabels", "monitoringNamespaceLabels", "fqdnEgress"],
      "properties": {
        "enabled": {
          "const": true
        },
        "apiIngressNamespaceLabels": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "monitoringNamespaceLabels": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "fqdnEgress": {
          "type": "object",
          "required": [
            "enabled",
            "dns",
            "api",
            "hedgeWorker",
            "analyticsWorker",
            "reconciliationWorker",
            "settlementIndexer",
            "toxicFlowAnalyzer"
          ],
          "properties": {
            "enabled": {
              "const": true
            },
            "dns": {
              "type": "object",
              "required": ["endpointLabels", "port"],
              "properties": {
                "endpointLabels": {
                  "type": "object",
                  "minProperties": 1,
                  "additionalProperties": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "port": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 65535
                }
              },
              "additionalProperties": false
            },
            "api": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "hedgeWorker": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "analyticsWorker": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "reconciliationWorker": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "settlementIndexer": {
              "$ref": "#/definitions/fqdnEndpointList"
            },
            "toxicFlowAnalyzer": {
              "$ref": "#/definitions/fqdnEndpointList"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}

# Backend HTTP server
HOST=127.0.0.1
PORT=3000

# Signed quote lifetime in seconds. Keep this short enough to limit stale price execution.
RFQ_QUOTE_TTL_SECONDS=30

# Maximum JSON request body size accepted by the backend gateway.
RFQ_BODY_LIMIT_BYTES=32768

# Comma-separated browser origins allowed by the backend CORS policy.
RFQ_CORS_ALLOWED_ORIGINS=http://localhost:5173

# Enable Strict-Transport-Security only behind HTTPS.
RFQ_ENABLE_HSTS=false

# Trust the first x-forwarded-for entry only behind a trusted reverse proxy.
RFQ_TRUST_PROXY=false

# Local development uses process-local rate limits. Non-local NODE_ENV requires redis.
RFQ_RATE_LIMIT_BACKEND=memory
# RFQ_REDIS_URL=redis://127.0.0.1:6379/0

# Frontend API target consumed by Vite. Override this for Docker, staging, or deployed APIs.
VITE_RFQ_API_BASE_URL=http://localhost:3000

# Frontend contract target and wallet connector configuration consumed by Vite.
# WalletConnect project id must be a safe string: letters, numbers, underscore, or hyphen.
VITE_RFQ_SETTLEMENT_ADDRESS=0x0000000000000000000000000000000000000004
VITE_WALLETCONNECT_PROJECT_ID=00000000000000000000000000000000

# Development-only Anvil private key. Replace this in any shared or deployed environment.
RFQ_SIGNER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# RFQSettlement verifying contract used in EIP-712 quote signatures.
RFQ_SETTLEMENT_ADDRESS=0x0000000000000000000000000000000000000004

# Local-only simulated settlement. Non-local NODE_ENV defaults this to false.
RFQ_ALLOW_SIMULATED_SETTLEMENT=true

# Receipt-confirmed mode configuration. RPC URLs commonly contain credentials; inject this as a secret in production.
# RFQ_RECEIPT_CONFIG_JSON={"chains":[{"chainId":1,"rpcUrl":"https://rpc.example.com","settlementAddress":"0x0000000000000000000000000000000000000004","confirmations":2,"receiptTimeoutMs":120000}]}

# Background market-data prefetch pairs.
# Format: chainId:tokenIn:tokenOut,chainId:tokenIn:tokenOut
# RFQ_MARKET_PAIRS=1:0x0000000000000000000000000000000000000002:0x0000000000000000000000000000000000000003

# Base market-data provider defaults to static. Chainlink requires an explicit JSON config.
# Feed token direction describes the aggregator answer; invert reverses that answer when true.
# L2 networks should configure both sequencerUptimeFeed and sequencerGracePeriodSeconds.
# RFQ_MARKET_DATA_PROVIDER=chainlink
# RFQ_CHAINLINK_CONFIG_JSON={"networks":[{"chainId":1,"networkType":"l1","rpcUrl":"https://rpc.example.com","feeds":[{"tokenIn":"0x0000000000000000000000000000000000000002","tokenOut":"0x0000000000000000000000000000000000000003","aggregator":"0x0000000000000000000000000000000000000004","decimals":8,"invert":false}]}],"referenceLiquidityUsd":"50000000","referenceVolatilityBps":25,"maxPriceAgeMs":60000}

# Optional CEX Level-2 sources. Add one entry per exchange; symbol direction must match tokenIn -> tokenOut.
# Format: chainId:tokenIn:tokenOut:exchange:symbol
# RFQ_CEX_PAIRS=1:0x0000000000000000000000000000000000000002:0x0000000000000000000000000000000000000003:binance:ETHUSDT,1:0x0000000000000000000000000000000000000002:0x0000000000000000000000000000000000000003:coinbase:ETH-USDT

# PostgreSQL database connection. Use the full URL for simplicity, or set DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD individually.
# DATABASE_URL=postgres://rfq:rfq@127.0.0.1:5432/rfq_market_maker

# Separate hedge-worker process. Use trade-only, IP-restricted Binance credentials with withdrawals disabled.
# RFQ_HEDGE_WORKER_HOST=127.0.0.1
# RFQ_HEDGE_WORKER_PORT=3001
# RFQ_HEDGE_LEASE_MS=30000
# RFQ_HEDGE_POLL_INTERVAL_MS=250
# RFQ_HEDGE_RETRY_DELAY_MS=1000
# RFQ_HEDGE_ROUTES_JSON={"routes":[{"chainId":1,"token":"0x0000000000000000000000000000000000000003","venue":"binance","symbol":"ETHUSDT","tokenDecimals":18,"stepSizeRaw":"100000000000000"}]}
# RFQ_BINANCE_API_KEY=replace-with-trade-only-key
# RFQ_BINANCE_API_SECRET=replace-with-secret
# RFQ_BINANCE_BASE_URL=https://testnet.binance.vision
# RFQ_BINANCE_RECV_WINDOW_MS=5000
# RFQ_BINANCE_REQUEST_TIMEOUT_MS=10000

# Transactional analytics pipeline: PostgreSQL outbox -> Redpanda -> ClickHouse.
# RFQ_ANALYTICS_WORKER_HOST=127.0.0.1
# RFQ_ANALYTICS_WORKER_PORT=3002
# RFQ_ANALYTICS_WORKER_ID=analytics_worker_local
# RFQ_ANALYTICS_KAFKA_BROKERS=127.0.0.1:19092
# RFQ_ANALYTICS_KAFKA_TOPIC=rfq.analytics.v1
# RFQ_ANALYTICS_KAFKA_CLIENT_ID=rfq-analytics
# RFQ_ANALYTICS_KAFKA_GROUP_ID=rfq-clickhouse-v1
# RFQ_ANALYTICS_KAFKA_SSL=false
# RFQ_ANALYTICS_BATCH_SIZE=10
# RFQ_ANALYTICS_LEASE_MS=120000
# RFQ_ANALYTICS_POLL_INTERVAL_MS=250
# RFQ_ANALYTICS_RETRY_DELAY_MS=1000
# RFQ_ANALYTICS_OUTBOX_RETENTION_MS=604800000
# RFQ_CLICKHOUSE_URL=http://127.0.0.1:8123
# RFQ_CLICKHOUSE_USERNAME=default
# RFQ_CLICKHOUSE_PASSWORD=
# RFQ_CLICKHOUSE_DATABASE=default
# RFQ_CLICKHOUSE_ANALYTICS_TABLE=rfq_analytics_events
